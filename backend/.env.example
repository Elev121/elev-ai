# ─────────────────────────────────────────────────────────────────────────────
# ELEV Backend — Environment Variables
#
# LOCAL DEVELOPMENT
#   cp .env.example .env
#   Fill in real values, then: npm run dev
#
# PRODUCTION (Railway)
#   Do NOT upload .env to Railway.
#   Set every variable below via: Railway dashboard → your service → Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional: override the model (default: claude-haiku-4-5-20251001)
# Faster/cheaper:  claude-haiku-4-5-20251001
# Higher quality:  claude-sonnet-4-6
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Production: Railway sets PORT automatically; set NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development : * (allow all — safe because the backend is only on localhost)
# Production  : In production the Netlify frontend proxies all /api/* requests
#               to Railway server-to-server, so browsers never make a
#               cross-origin request.  * is therefore still safe, but you can
#               lock it down to your Netlify URL for extra security.
#
#   Local dev:         CORS_ORIGIN=*
#   Production (open): CORS_ORIGIN=*
#   Production (tight):CORS_ORIGIN=https://your-site.netlify.app
#
# Multiple origins (comma-separated):
#   CORS_ORIGIN=https://your-site.netlify.app,https://www.your-custom-domain.com
CORS_ORIGIN=*

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100             # requests per window per IP

# ── Qdrant Vector Database ────────────────────────────────────────────────────
# Sign up at https://cloud.qdrant.io — free tier is sufficient for development.
# Leave blank to disable vector store (analysis still works, no semantic retrieval).
QDRANT_URL=https://YOUR-CLUSTER-ID.YOUR-REGION.gcp.cloud.qdrant.io
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=elev_chunks

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Optional — enables Firestore persistence of analysis results.
# Without these, results are held in memory (lost on server restart).
#
# How to get these values:
#   Firebase Console → Project Settings → Service Accounts
#   → Generate New Private Key → download JSON → copy values below
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# ── OCR (optional) ────────────────────────────────────────────────────────────
# Maximum number of scanned pages to OCR per upload (default: 8).
# Higher values increase processing time significantly.
# MAX_OCR_PAGES=8
