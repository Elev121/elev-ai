# ── Environment variables ─────────────────────────────────────────────────────
# NEVER commit real credentials. Copy .env.example → .env and fill it in locally.
backend/.env
.env
*.env.local
*.env.production

# ── Node modules ──────────────────────────────────────────────────────────────
backend/node_modules/
node_modules/

# ── Uploaded PDF files (temporary, ephemeral) ─────────────────────────────────
backend/uploads/

# ── Auto-generated Netlify proxy file ─────────────────────────────────────────
# Created by scripts/build.sh at Netlify build time from the BACKEND_URL env var.
# Do not commit — it will contain your production Railway URL.
frontend/_redirects

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor artefacts ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# ── Netlify CLI cache ─────────────────────────────────────────────────────────
.netlify/
